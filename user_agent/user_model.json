{
    "_comment": "Oracle (User Agent) model registry. Each key is a user-model-name passed to the harness / init endpoint. Its value is a LIST of interchangeable backend endpoints (same model, different providers/tokens) that are load-balanced round-robin with skip-on-failure. Replace every <...> placeholder with your own gateway URL / token. Supports api_type 'anthropic' and 'openai'.",

    "DeepSeek-V3.2": [
        {
            "api_type": "anthropic",
            "model_name": "<provider-model-id>",
            "base_url": "<https://your-anthropic-gateway/v1/anthropic/>",
            "auth_token": "<YOUR_TOKEN>"
        },
        {
            "api_type": "anthropic",
            "model_name": "<provider-model-id-2>",
            "base_url": "<https://your-anthropic-gateway/v1/anthropic/>",
            "auth_token": "<YOUR_TOKEN_2>"
        }
    ],

    "Gemini-3.1-Flash-Lite": [
        {
            "api_type": "anthropic",
            "model_name": "<provider-model-id>",
            "base_url": "<https://your-anthropic-gateway/v1/anthropic/>",
            "auth_token": "<YOUR_TOKEN>"
        }
    ],

    "Qwen3.5-4B": [
        {
            "api_type": "openai",
            "model_name": "<provider-model-id>",
            "base_url": "<http://your-openai-compatible-host/v1>",
            "api_key": "<YOUR_API_KEY>"
        }
    ]
}
